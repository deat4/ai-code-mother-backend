t: '';\\n            position: absolute;\\n            bottom: -4px;\\n            left: 0;\\n            width: 0;\\n            height: 2px;\\n            background: #f77f00;\\n            transition: width 0.3s;\\n        }\\n\\n        .nav-links a:hover {\\n            color: #f77f00;\\n        }\\n\\n        .nav-links a:hover::after {\\n            width: 100%;\\n        }\\n\\n        /* 移动端菜单按钮 */\\n        .menu-toggle {\\n            display: none;\\n            background: none;\\n            border: none;\\n            font-size: 1.8rem;\\n            cursor: pointer;\\n            color: #2b2d42;\\n        }\\n\\n        /* ===== Hero 区域 ===== */\\n        .hero {\\n            background: linear-gradient(135deg, #2b2d42 0%, #3a3d5c 100%);\\n            color: #fff;\\n            padding: 100px 0 80px;\\n            text-align: center;\\n        }\\n\\n        .hero h1 {\\n            font-size: 3.2rem;\\n            font-weight: 800;\\n            margin-bottom: 20px;\\n            letter-spacing: 1px;\\n        }\\n\\n        .hero h1 span {\\n            color: #f77f00;\\n        }\\n\\n        .hero p {\\n            font-size: 1.2rem;\\n            max-width: 700px;\\n            margin: 0 auto 40px;\\n            opacity: 0.9;\\n        }\\n\\n        .hero .btn-group {\\n            display: flex;\\n            justify-content: center;\\n            gap: 20px;\\n            flex-wrap: wrap;\\n        }\\n\\n        .btn {\\n            display: inline-block;\\n            padding: 14px 36px;\\n            border-radius: 50px;\\n            font-weight: 600;\\n            font-size: 1rem;\\n            transition: all 0.3s;\\n            cursor: pointer;\\n            border: 2px solid transparent;\\n        }\\n\\n        .btn-primary {\\n            background: #f77f00;\\n            color: #fff;\\n            border-color: #f77f00;\\n        }\\n\\n        .btn-primary:hover {\\n            background: #e67300;\\n            border-color: #e67300;\\n            transform: translateY(-2px);\\n            box-shadow: 0 8px 20px rgba(247,127,0,0.35);\\n        }\\n\\n        .btn-outline {\\n            background: transparent;\\n            color: #fff;\\n            border-color: #fff;\\n        }\\n\\n        .btn-outline:hover {\\n            background: #fff;\\n            color: #2b2d42;\\n            transform: translateY(-2px);\\n        }\\n\\n        /* ===== 服务/特色卡片 ===== */\\n        .section {\\n            padding: 80px 0;\\n        }\\n\\n        .section-title {\\n            text-align: center;\\n            font-size: 2.4rem;\\n            font-weight: 700;\\n            margin-bottom: 16px;\\n            color: #2b2d42;\\n        }\\n\\n        .section-subtitle {\\n            text-align: center;\\n            color: #6c6f85;\\n            margin-bottom: 60px;\\n            font-size: 1.1rem;\\n        }\\n\\n        .cards-grid {\\n            display: grid;\\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\\n            gap: 32px;\\n        }\\n\\n        .card {\\n            background: #fff;\\n            border-radius: 20px;\\n            padding: 36px 28px;\\n            box-shadow: 0 8px 30px rgba(0,0,0,0.05);\\n            transition: transform 0.3s, box-shadow 0.3s;\\n            text-align: center;\\n        }\\n\\n        .card:hover {\\n            transform: translateY(-8px);\\n            box-shadow: 0 16px 40px rgba(0,0,0,0.1);\\n        }\\n\\n        .card .icon {\\n            font-size: 3rem;\\n            margin-bottom: 20px;\\n            display: block;\\n        }\\n\\n        .card h3 {\\n            font-size: 1.5rem;\\n            margin-bottom: 12px;\\n            color: #2b2d42;\\n        }\\n\\n        .card p {\\n            color: #6c6f85;\\n            font-size: 0.95rem;\\n        }\\n\\n        /* ===== 作品集 Tab 切换 ===== */\\n        .portfolio-tabs {\\n            display: flex;\\n            justify-content: center;\\n            gap: 12px;\\n            margin-bottom: 40px;\\n            flex-wrap: wrap;\\n        }\\n\\n        .tab-btn {\\n            padding: 10px 28px;\\n            border: 2px solid #e0e0e8;\\n            border-radius: 50px;\\n            background: #fff;\\n            font-weight: 500;\\n            cursor: pointer;\\n            transition: all 0.3s;\\n            font-size: 0.95rem;\\n        }\\n\\n        .tab-btn.active {\\n            background: #f77f00;\\n            color: #fff;\\n            border-color: #f77f00;\\n        }\\n\\n        .tab-btn:hover:not(.active) {\\n            border-color: #f77f00;\\n            color: #f77f00;\\n        }\\n\\n        .portfolio-grid {\\n            display: grid;\\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\\n            gap: 24px;\\n        }\\n\\n        .portfolio-item {\\n            border-radius: 16px;\\n            overflow: hidden;\\n            box-shadow: 0 4px 16px rgba(0,0,0,0.06);\\n            transition: transform 0.3s;\\n            background: #fff;\\n        }\\n\\n        .portfolio-item:hover {\\n            transform: scale(1.02);\\n        }\\n\\n        .portfolio-item img {\\n            width: 100%;\\n            height: 220px;\\n            object-fit: cover;\\n        }\\n\\n        .portfolio-item .info {\\n            padding: 18px 20px;\\n        }\\n\\n        .portfolio-item .info h4 {\\n            font-size: 1.1rem;\\n            margin-bottom: 6px;\\n        }\\n\\n        .portfolio-item .info p {\\n            color: #6c6f85;\\n            font-size: 0.9rem;\\n        }\\n\\n        /* ===== 联系表单 ===== */\\n        .contact-form {\\n            max-width: 640px;\\n            margin: 0 auto;\\n            background: #fff;\\n            padding: 48px 40px;\\n            border-radius: 24px;\\n            box-shadow: 0 8px 30px rgba(0,0,0,0.05);\\n        }\\n\\n        .form-group {\\n            margin-bottom: 24px;\\n        }\\n\\n        .form-group label {\\n            display: block;\\n            font-weight: 600;\\n            margin-bottom: 8px;\\n            color: #2b2d42;\\n        }\\n\\n        .form-group input,\\n        .form-group textarea {\\n            width: 100%;\\n            padding: 14px 18px;\\n            border: 2px solid #e0e0e8;\\n            border-radius: 12px;\\n            font-size: 1rem;\\n            transition: border-color 0.3s;\\n            font-family: inherit;\\n            background: #f9f9fb;\\n        }\\n\\n        .form-group input:focus,\\n        .form-group textarea:focus {\\n            outline: none;\\n            border-color: #f77f00;\\n        }\\n\\n        .form-group textarea {\\n            resize: vertical;\\n            min-height: 120px;\\n        }\\n\\n        .form-submit-btn {\\n            width: 100%;\\n            padding: 16px;\\n            background: #f77f00;\\n            color: #fff;\\n            border: none;\\n            border-radius: 50px;\\n            font-size: 1.1rem;\\n            font-weight: 600;\\n            cursor: pointer;\\n            transition: background 0.3s, transform 0.2s;\\n        }\\n\\n        .form-submit-btn:hover {\\n            background: #e67300;\\n            transform: translateY(-2px);\\n        }\\n\\n        /* ===== Footer ===== */\\n        .footer {\\n            background: #2b2d42;\\n            color: #b0b3c9;\\n            text-align: center;\\n            padding: 40px 24px;\\n            margin-top: 40px;\\n        }\\n\\n        .footer p {\\n            margin-bottom: 8px;\\n            font-size: 0.95rem;\\n        }\\n\\n        .footer .social-links {\\n            display: flex;\\n            justify-content: center;\\n            gap: 24px;\\n            margin-top: 16px;\\n        }\\n\\n        .footer .social-links a {\\n            color: #b0b3c9;\\n            font-size: 1.4rem;\\n            transition: color 0.3s;\\n        }\\n\\n        .footer .social-links a:hover {\\n            color: #f77f00;\\n        }\\n\\n        /* ===== 响应式 ===== */\\n        @media (max-width: 768px) {\\n            .nav-links {\\n                display: none;\\n                flex-direction: column;\\n                background: #fff;\\n                position: absolute;\\n                top: 70px;\\n                left: 0;\\n                width: 100%;\\n                padding: 24px 32px;\\n                box-shadow: 0 8px 20px rgba(0,0,0,0.08);\\n                gap: 20px;\\n            }\\n\\n            .nav-links.open {\\n                display: flex;\\n            }\\n\\n            .menu-toggle {\\n                display: block;\\n            }\\n\\n            .hero h1 {\\n                font-size: 2.2rem;\\n            }\\n\\n            .hero p {\\n                font-size: 1rem;\\n            }\\n\\n            .section-title {\\n                font-size: 1.8rem;\\n            }\\n\\n            .contact-form {\\n                padding: 32px 20px;\\n            }\\n        }\\n\\n        @media (max-width: 480px) {\\n            .hero {\\n                padding: 70px 0 60px;\\n            }\\n\\n            .hero h1 {\\n                font-size: 1.8rem;\\n            }\\n\\n            .btn {\\n                padding: 12px 28px;\\n                font-size: 0.9rem;\\n            }\\n\\n            .portfolio-grid {\\n                grid-template-columns: 1fr;\\n            }\\n        }\\n    </style>\\n</head>\\n<body>\\n\\n    <!-- ===== 导航栏 ===== -->\\n    <nav class=\\\"navbar\\\">\\n        <div class=\\\"container\\\">\\n            <div class=\\\"logo\\\">标<span>願</span></div>\\n            <button class=\\\"menu-toggle\\\" id=\\\"menuToggle\\\" aria-label=\\\"菜单\\\">☰</button>\\n            <ul class=\\\"nav-links\\\" id=\\\"navLinks\\\">\\n                <li><a href=\\\"#services\\\">服务</a></li>\\n                <li><a href=\\\"#portfolio\\\">作品</a></li>\\n                <li><a href=\\\"#contact\\\">联系</a></li>\\n            </ul>\\n        </div>\\n    </nav>\\n\\n    <!-- ===== Hero ===== -->\\n    <section class=\\\"hero\\\">\\n        <div class=\\\"container\\\">\\n            <h1>用设计点亮 <span>品牌愿景</span></h1>\\n            <p>我们专注于品牌策略与视觉设计，帮助每一个梦想找到独特的表达方式。从标志到完整品牌系统，标願与你一起创造令人难忘的品牌体验。</p>\\n            <div class=\\\"btn-group\\\">\\n                <a href=\\\"#portfolio\\\" class=\\\"btn btn-primary\\\">查看作品</a>\\n                <a href=\\\"#contact\\\" class=\\\"btn btn-outline\\\">开始合作</a>\\n            </div>\\n        </div>\\n    </section>\\n\\n    <!-- ===== 服务卡片 ===== -->\\n    <section class=\\\"section\\\" id=\\\"services\\\">\\n        <div class=\\\"container\\\">\\n            <h2 class=\\\"section-title\\\">我们的服务</h2>\\n            <p class=\\\"section-subtitle\\\">从策略到落地，全链路品牌设计</p>\\n            <div class=\\\"cards-grid\\\">\\n                <div class=\\\"card\\\">\\n                    <span class=\\\"icon\\\">🎯</span>\\n                    <h3>品牌策略</h3>\\n                    <p>深入洞察市场与用户，制定清晰的品牌定位与传播策略，让品牌从诞生就与众不同。</p>\\n                </div>\\n                <div class=\\\"card\\\">\\n                    <span class=\\\"icon\\\">✨</span>\\n                    <h3>视觉识别</h3>\\n                    <p>Logo、色彩、字体、图形系统 — 打造统一而富有识别度的品牌视觉语言。</p>\\n                </div>\\n                <div class=\\\"card\\\">\\n                    <span class=\\\"icon\\\">📱</span>\\n                    <h3>数字设计</h3>\\n                    <p>网站、App、社交媒体素材 — 在每一个数字触点传递品牌的核心价值。</p>\\n                </div>\\n            </div>\\n        </div>\\n    </section>\\n\\n    <!-- ===== 作品集 (Tab切换) ===== -->\\n    <section class=\\\"section\\\" id=\\\"portfolio\\\">\\n        <div class=\\\"container\\\">\\n            <h2 class=\\\"section-title\\\">精选作品</h2>\\n            <p class=\\\"section-subtitle\\\">每个项目都是一次品牌叙事的全新探索</p>\\n\\n            <div class=\\\"portfolio-tabs\\\" id=\\\"portfolioTabs\\\">\\n                <button class=\\\"tab-btn active\\\" data-filter=\\\"all\\\">全部</button>\\n                <button class=\\\"tab-btn\\\" data-filter=\\\"brand\\\">品牌</button>\\n                <button class=\\\"tab-btn\\\" data-filter=\\\"digital\\\">数字</button>\\n                <button class=\\\"tab-btn\\\" data-filter=\\\"print\\\">印刷</button>\\n            </div>\\n\\n            <div class=\\\"portfolio-grid\\\" id=\\\"portfolioGrid\\\">\\n                <!-- 项目由 JS 动态生成 -->\\n            </div>\\n        </div>\\n    </section>\\n\\n    <!-- ===== 联系表单 ===== -->\\n    <section class=\\\"section\\\" id=\\\"contact\\\">\\n        <div class=\\\"container\\\">\\n            <h2 class=\\\"section-title\\\">联系我们</h2>\\n            <p class=\\\"section-subtitle\\\">告诉我们你的项目，一起让愿景成为现实</p>\\n            <form class=\\\"contact-form\\\" id=\\\"contactForm\\\">\\n                <div class=\\\"form-group\\\">\\n                    <label for=\\\"name\\\">姓名</label>\\n                    <input type=\\\"text\\\" id=\\\"name\\\" placeholder=\\\"你的名字\\\" required>\\n                </div>\\n                <div class=\\\"form-group\\\">\\n                    <label for=\\\"email\\\">邮箱</label>\\n                    <input type=\\\"email\\\" id=\\\"email\\\" placeholder=\\\"your@email.com\\\" required>\\n                </div>\\n                <div class=\\\"form-group\\\">\\n                    <label for=\\\"message\\\">项目描述</label>\\n                    <textarea id=\\\"message\\\" placeholder=\\\"请简要描述你的项目或需求...\\\" required></textarea>\\n                </div>\\n                <button type=\\\"submit\\\" class=\\\"form-submit-btn\\\">发送消息</button>\\n            </form>\\n        </div>\\n    </section>\\n\\n    <!-- ===== Footer ===== -->\\n    <footer class=\\\"footer\\\">\\n        <div class=\\\"container\\\">\\n            <p>&copy; 2025 标願品牌设计. All rights reserved.</p>\\n            <p>用设计点亮品牌愿景</p>\\n            <div class=\\\"social-links\\\">\\n                <a href=\\\"#\\\" aria-label=\\\"微信\\\">💬</a>\\n                <a href=\\\"#\\\" aria-label=\\\"微博\\\">📱</a>\\n                <a href=\\\"#\\\" aria-label=\\\"小红书\\\">📕</a>\\n            </div>\\n        </div>\\n    </footer>\\n\\n    <!-- ===== JavaScript ===== -->\\n    <script>\\n        (function() {\\n            'use strict';\\n\\n            // 1. 移动端菜单切换\\n            const menuToggle = document.getElementById('menuToggle');\\n            const navLinks = document.getElementById('navLinks');\\n\\n            menuToggle.addEventListener('click', function() {\\n                navLinks.classList.toggle('open');\\n            });\\n\\n            // 点击导航链接后关闭菜单 (移动端体验)\\n            document.querySelectorAll('.nav-links a').forEach(link => {\\n                link.addEventListener('click', () => {\\n                    navLinks.classList.remove('open');\\n                });\\n            });\\n\\n            // 2. 作品集数据\\n            const portfolioData = [\\n                { id: 1, title: '云栖茶室', category: 'brand', img: 'https://picsum.photos/seed/brand1/600/400', desc: '高端茶品牌全案设计' },\\n                { id: 2, title: '极光旅行', category: 'digital', img: 'https://picsum.photos/seed/digital1/600/400', desc: '旅行App界面与品牌重塑' },\\n                { id: 3, title: '墨韵文创', category: 'print', img: 'https://picsum.photos/seed/print1/600/400', desc: '文创产品包装与画册' },\\n                { id: 4, title: '星澜科技', category: 'brand', img: 'https://picsum.photos/seed/brand2/600/400', desc: '科技公司品牌升级' },\\n                { id: 5, title: '悦动健身', category: 'digital', img: 'https://picsum.photos/seed/digital2/600/400', desc: '健身品牌数字触点设计' },\\n                { id: 6, title: '草木集', category: 'print', img: 'https://picsum.photos/seed/print2/600/400', desc: '自然系品牌印刷物料' }\\n            ];\\n\\n            const portfolioGrid = document.getElementById('portfolioGrid');\\n            const tabBtns = document.querySelectorAll('.tab-btn');\\n\\n            // 渲染作品\\n            function renderPortfolio(filter = 'all') {\\n                const filtered = filter === 'all' \\n                    ? portfolioData \\n                    : portfolioData.filter(item => item.category === filter);\\n\\n                portfolioGrid.innerHTML = filtered.map(item => `\\n                    <div class=\\\"portfolio-item\\\">\\n                        <img src=\\\"${item.img}\\\" alt=\\\"${item.title}\\\" loading=\\\"lazy\\\">\\n                        <div class=\\\"info\\\">\\n                            <h4>${item.title}</h4>\\n                            <p>${item.desc}</p>\\n                        </div>\\n                    </div>\\n                `).join('');\\n            }\\n\\n            // Tab 切换事件\\n            tabBtns.forEach(btn => {\\n                btn.addEventListener('click', function() {\\n                    // 移除所有 active\\n                    tabBtns.forEach(b => b.classList.remove('active'));\\n                    this.classList.add('active');\\n\\n                    const filter = this.getAttribute('data-filter');\\n                    renderPortfolio(filter);\\n                });\\n            });\\n\\n            // 初始渲染全部\\n            renderPortfolio('all');\\n\\n            // 3. 表单提交提示\\n            const contactForm = document.getElementById('contactForm');\\n            contactForm.addEventListener('submit', function(e) {\\n                e.preventDefault();\\n\\n                const name = document.getElementById('name').value.trim();\\n                const email = document.getElementById('email').value.trim();\\n                const message = document.getElementById('message').value.trim();\\n\\n                if (!name || !email || !message) {\\n                    alert('请填写所有必填字段。');\\n                    return;\\n                }\\n\\n                // 简单邮箱格式校验\\n                if (!/\\\\S+@\\\\S+\\\\.\\\\S+/.test(email)) {\\n                    alert('请输入有效的邮箱地址。');\\n                    return;\\n                }\\n\\n                alert(`感谢你的留言，${name}！我们会在24小时内通过 ${email} 与你联系。`);\\n                contactForm.reset();\\n            });\\n\\n        })();\\n    </script>\\n\\n</body>\\n</html>\"\n}\n```"
