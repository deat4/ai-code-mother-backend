t: '';\\n            position: absolute;\\n            bottom: -4px;\\n            left: 0;\\n            width: 0;\\n            height: 2px;\\n            background: #f77f00;\\n            transition: width 0.3s;\\n        }\\n\\n        .nav-links a:hover {\\n            color: #f77f00;\\n        }\\n\\n        .nav-links a:hover::after {\\n            width: 100%;\\n        }\\n\\n        /* 移动端菜单按钮 */\\n        .menu-toggle {\\n            display: none;\\n            background: none;\\n            border: none;\\n            font-size: 1.8rem;\\n            cursor: pointer;\\n            color: #2b2d42;\\n        }\\n\\n        /* ===== Hero 区域 ===== */\\n        .hero {\\n            background: linear-gradient(135deg, #2b2d42 0%, #3a3d5c 100%);\\n            color: #fff;\\n            padding: 100px 0 80px;\\n            text-align: center;\\n        }\\n\\n        .hero h1 {\\n            font-size: 3.2rem;\\n            font-weight: 800;\\n            margin-bottom: 20px;\\n            letter-spacing: 1px;\\n        }\\n\\n        .hero h1 span {\\n            color: #f77f00;\\n        }\\n\\n        .hero p {\\n            font-size: 1.2rem;\\n            max-width: 700px;\\n            margin: 0 auto 40px;\\n            opacity: 0.9;\\n        }\\n\\n        .hero .btn-group {\\n            display: flex;\\n            justify-content: center;\\n            gap: 20px;\\n            flex-wrap: wrap;\\n        }\\n\\n        .btn {\\n            display: inline-block;\\n            padding: 14px 36px;\\n            border-radius: 50px;\\n            font-weight: 600;\\n            font-size: 1rem;\\n            transition: all 0.3s;\\n            cursor: pointer;\\n            border: 2px solid transparent;\\n        }\\n\\n        .btn-primary {\\n            background: #f77f00;\\n            color: #fff;\\n            border-color: #f77f00;\\n        }\\n\\n        .btn-primary:hover {\\n            background: #e67300;\\n            border-color: #e67300;\\n            transform: translateY(-2px);\\n            box-shadow: 0 8px 20px rgba(247,127,0,0.35);\\n        }\\n\\n        .btn-outline {\\n            background: transparent;\\n            color: #fff;\\n            border-color: #fff;\\n        }\\n\\n        .btn-outline:hover {\\n            background: #fff;\\n            color: #2b2d42;\\n            transform: translateY(-2px);\\n        }\\n\\n        /* ===== 服务/特色卡片 ===== */\\n        .section {\\n            padding: 80px 0;\\n        }\\n\\n        .section-title {\\n            text-align: center;\\n            font-size: 2.4rem;\\n            font-weight: 700;\\n            margin-bottom: 16px;\\n            color: #2b2d42;\\n        }\\n\\n        .section-subtitle {\\n            text-align: center;\\n            color: #6c6f85;\\n            margin-bottom: 60px;\\n            font-size: 1.1rem;\\n        }\\n\\n        .cards-grid {\\n            display: grid;\\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\\n            gap: 32px;\\n        }\\n\\n        .card {\\n            background: #fff;\\n            border-radius: 20px;\\n            padding: 36px 28px;\\n            box-shadow: 0 8px 30px rgba(0,0,0,0.05);\\n            transition: transform 0.3s, box-shadow 0.3s;\\n            text-align: center;\\n        }\\n\\n        .card:hover {\\n            transform: translateY(-8px);\\n            box-shadow: 0 16px 40px rgba(0,0,0,0.1);\\n        }\\n\\n        .card .icon {\\n            font-size: 3rem;\\n            margin-bottom: 20px;\\n            display: block;\\n        }\\n\\n        .card h3 {\\n            font-size: 1.5rem;\\n            margin-bottom: 12px;\\n            color: #2b2d42;\\n        }\\n\\n        .card p {\\n            color: #6c6f85;\\n            font-size: 0.95rem;\\n        }\\n\\n        /* ===== 作品集 Tab 切换 ===== */\\n        .portfolio-tabs {\\n            display: flex;\\n            justify-content: center;\\n        